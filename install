#!/usr/bin/env bash
set -euo pipefail

REPO="pebrd/voxtype-tray"
BINARY="voxtype-tray"
INSTALL_DIR="${HOME}/.local/bin"

# ─── helpers ──────────────────────────────────────────────────────────────────
info()  { printf "\033[1;34m==>\033[0m %s\n" "$*"; }
ok()    { printf "\033[1;32m ✓\033[0m %s\n" "$*"; }
err()   { printf "\033[1;31m ✗\033[0m %s\n" "$*"; exit 1; }

# ─── prerequisites ────────────────────────────────────────────────────────────
info "Verificando dependencias..."

if ! command -v cargo &>/dev/null; then
    err "Rust no está instalado. https://rustup.rs/"
fi

if ! pkg-config --exists dbus-1 2>/dev/null; then
    err "Falta libdbus-1-dev.\n  Debian/Ubuntu: sudo apt install libdbus-1-dev pkg-config\n  Arch:          sudo pacman -S dbus pkgconf\n  Fedora:        sudo dnf install dbus-devel pkgconfig"
fi

ok "Dependencias ok"

# ─── temp work dir ────────────────────────────────────────────────────────────
WORKDIR="$(mktemp -d)"
trap 'rm -rf "$WORKDIR"' EXIT

# ─── download & build ─────────────────────────────────────────────────────────
info "Descargando $REPO..."
git clone --depth=1 "https://github.com/$REPO.git" "$WORKDIR/$BINARY" 2>/dev/null || {
    # fallback: descargar tarball
    curl -sL "https://github.com/$REPO/archive/refs/heads/main.tar.gz" | tar xz -C "$WORKDIR"
    mv "$WORKDIR/${BINARY}-main" "$WORKDIR/$BINARY"
}

info "Compilando $BINARY (release)..."
cargo build --release --manifest-path "$WORKDIR/$BINARY/Cargo.toml" 2>/dev/null

# ─── install binary ───────────────────────────────────────────────────────────
info "Instalando $BINARY en $INSTALL_DIR..."
mkdir -p "$INSTALL_DIR"
cp "$WORKDIR/$BINARY/target/release/$BINARY" "$INSTALL_DIR/$BINARY"
chmod +x "$INSTALL_DIR/$BINARY"
ok "Binario instalado"

# ─── systemd user service ─────────────────────────────────────────────────────
SERVICE_DIR="${HOME}/.config/systemd/user"
SERVICE_NAME="$BINARY"

info "Instalando servicio systemd..."
mkdir -p "$SERVICE_DIR"

cat > "$SERVICE_DIR/$SERVICE_NAME.service" <<SERVICEEOF
[Unit]
Description=Voxtype system tray indicator
After=graphical-session.target
PartOf=graphical-session.target

[Service]
Type=simple
ExecStart=${INSTALL_DIR}/${BINARY}
Restart=on-failure
RestartSec=3

[Install]
WantedBy=graphical-session.target
SERVICEEOF

systemctl --user daemon-reload
systemctl --user enable --now "$SERVICE_NAME" 2>/dev/null || true

ok "Servicio iniciado"

echo ""
echo "  Logs:        journalctl --user -u $SERVICE_NAME -f"
echo "  Detener:     systemctl --user stop $SERVICE_NAME"
echo "  Desinstalar: systemctl --user disable --now $SERVICE_NAME && rm $INSTALL_DIR/$BINARY"
